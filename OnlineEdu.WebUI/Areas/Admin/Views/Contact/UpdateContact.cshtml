@model UpdateContactDto

@{
    ViewData["Title"] = "Yeni iletişim oluşturma sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.5rem;
        padding-top: 1rem;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: 0.5px solid #e0e0de;
        color: #6b6b68;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 13px;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #f5f5f4;
            color: #1a1a1a;
            text-decoration: none;
        }

    .page-title {
        font-size: 18px;
        font-weight: 500;
        margin: 0;
        color: #1a1a1a;
    }

    .section-card {
        background: #ffffff;
        border: 0.5px solid #e0e0de;
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 500;
        color: #888780;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 1rem;
    }

    .field {
        margin-bottom: 1rem;
    }

        .field:last-child {
            margin-bottom: 0;
        }

        .field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #6b6b68;
            margin-bottom: 6px;
        }

        .field .form-control {
            font-size: 14px;
            border: 0.5px solid #e0e0de;
            border-radius: 8px;
            padding: 8px 12px;
            color: #1a1a1a;
            background: #ffffff;
            width: 100%;
            box-sizing: border-box;
        }

            .field .form-control:focus {
                outline: none;
                border-color: #888780;
                box-shadow: none;
            }

        .field textarea.form-control {
            resize: vertical;
            min-height: 110px;
            line-height: 1.6;
        }

    .char-count {
        font-size: 11px;
        color: #b4b2a9;
        text-align: right;
        margin-top: 4px;
    }

    .img-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .img-preview {
        margin-top: 6px;
        height: 56px;
        border-radius: 8px;
        border: 0.5px dashed #e0e0de;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9f9f8;
        color: #b4b2a9;
        font-size: 12px;
        gap: 6px;
        overflow: hidden;
    }

        .img-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 7px;
        }

    .items-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .item-field {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .item-num {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: #f5f5f4;
        border: 0.5px solid #e0e0de;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
        color: #6b6b68;
        flex-shrink: 0;
    }

    .item-field .form-control {
        flex: 1;
    }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding-top: 0.5rem;
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: 0.5px solid #e0e0de;
        color: #6b6b68;
        border-radius: 8px;
        padding: 8px 18px;
        font-size: 13px;
        text-decoration: none;
        cursor: pointer;
    }

        .btn-cancel:hover {
            background: #f5f5f4;
            color: #1a1a1a;
            text-decoration: none;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a1a;
        border: none;
        color: #ffffff;
        border-radius: 8px;
        padding: 8px 20px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }

        .btn-save:hover {
            opacity: 0.85;
        }

    .validation-message {
        font-size: 12px;
        color: #a32d2d;
        margin-top: 4px;
    }
</style>

<div class="page-header">
    <a asp-action="Index" asp-controller="Contact" asp-area="Admin" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="page-title">İletişim güncelleme alanı</h4>
</div>

<form method="post">
    <input type="hidden" asp-for="ContactId" />
    <label>Harita Url </label>
    <input type="text" asp-for="MapUrl" class="form-control" />
    <br />
    <label>Adres </label>
    <input type="text" asp-for="Address" class="form-control" />
    <br />
    <label>Telefon </label>
    <input type="text" asp-for="Phone" class="form-control" />
    <br />
    <label>Email </label>
    <input type="text" asp-for="Email" class="form-control" />
    <br />
    <div class="form-footer">
        <a asp-action="Index" asp-controller="Contact" asp-area="Admin" class="btn-cancel">
            İptal
        </a>
        <button type="submit" class="btn-save">
            <i class="bi bi-floppy"></i> Güncelle
        </button>
    </div>
</form>