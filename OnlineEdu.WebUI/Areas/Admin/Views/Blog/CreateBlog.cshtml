@model CreateBlogDto

@{
    ViewData["Title"] = "Blog Ekleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>

    .section-card {
        background: #ffffff;
        border: 0.5px solid #e0e0de;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .field label {
            font-size: 13px;
            font-weight: 500;
            color: #555;
        }

    .form-control {
        border: 0.5px solid #dcdcd8;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 15px;
        box-shadow: none !important;
    }

        .form-control:focus {
            border-color: #1a1a1a;
        }

    .banner-preview {
        margin-top: 14px;
        width: 100%;
        height: 220px;
        border-radius: 14px;
        border: 1px dashed #d8d8d5;
        background: #f8f8f7;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 8px;
        color: #a1a19d;
        overflow: hidden;
    }

        .banner-preview i {
            font-size: 28px;
        }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a1a;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
    }

        .btn-save:hover {
            opacity: 0.9;
            color: #fff;
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 0.5px solid #d6d6d2;
        background: #fff;
        color: #555;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
    }

        .btn-cancel:hover {
            background: #f5f5f4;
            color: #1a1a1a;
        }

    .img-preview span {
        font-size: 13px;
    }
</style>

<form method="post"
      asp-action="CreateBlog"
      asp-controller="Blog"
      asp-area="Admin">

    <div class="section-card">

        <div class="section-label">
            <i class="bi bi-type"></i>
            Blog Bilgisi
        </div>

        <div class="field">

            <label asp-for="Title">Başlık</label>

            <input type="text"
                   asp-for="Title"
                   class="form-control"
                   placeholder="blog başlığını giriniz..." />

        </div>
        <br />
        <div class="field">
            <label asp-for="Content">içerik metni</label>
            <textarea asp-for="Content" class="form-control" rows="5"
                      placeholder="Kendini kısaca anlat..."
                      oninput="document.getElementById('charcount').textContent=this.value.length+' karakter'"></textarea>
            <div class="char-count" id="charcount">0 karakter</div>
            <span asp-validation-for="Content" class="validation-message"></span>
        </div>

        <div class="field">
            <label asp-for="BlogCategoryId">Kategori</label>            
            <select asp-for="BlogCategoryId"
                    class="form-control"
                    asp-items="@((IEnumerable<SelectListItem>)ViewBag.categories)"
                    style="height: 45px; font-size: 15px; padding: 8px 12px;">
                <option value="">Kategori Seçin</option>
            </select>
        </div>
    </div>

    <div class="section-card">

        <div class="section-label">
            <i class="bi bi-image"></i>
            Blog Görseli
        </div>

        <div class="field">

            <label asp-for="ImageUrl">Resim URL</label>

            <input type="text"
                   asp-for="ImageUrl"
                   class="form-control"
                   placeholder="https://example.com/blog.jpg"
                   oninput="updateBlogPreview(this.value)" />

            <div class="banner-preview" id="blogPreview">
                <i class="bi bi-image"></i>
                <span>blog Önizleme</span>
            </div>

        </div>

    </div>

    <div class="form-footer">

        <a asp-action="Index"
           asp-controller="Blog"
           asp-area="Admin"
           class="btn-cancel">
            <i class="bi bi-arrow-left"></i>
            İptal
        </a>

        <button type="submit" class="btn-save">
            <i class="bi bi-floppy"></i>
            Kaydet
        </button>

    </div>

</form>

<script>

    function updateBlogPreview(url) {

        const preview = document.getElementById("blogPreview");

        if (url && url.trim() !== "") {

            preview.innerHTML =
                `<img src="${url}"
                      style="width:100%; height:220px; object-fit:cover; border-radius:14px;"
                      onerror="this.parentElement.innerHTML='<i class=\'bi bi-image\'></i><span>Görsel yüklenemedi</span>'" />`;

        }
        else {

            preview.innerHTML =
                `<i class="bi bi-image"></i><span>Banner Önizleme</span>`;
        }
    }        

</script>

