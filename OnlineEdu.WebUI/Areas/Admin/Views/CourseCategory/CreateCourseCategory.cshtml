@model CreateCourseCategoryDto

@{
    ViewData["Title"] = "Yeni Kurs Kategori Ekleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>

    .section-card {
        background: #ffffff;
        border: 0.5px solid #e0e0de;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .field label {
            font-size: 13px;
            font-weight: 500;
            color: #555;
        }

    .form-control {
        border: 0.5px solid #dcdcd8;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 13px;
        box-shadow: none !important;
    }

        .form-control:focus {
            border-color: #1a1a1a;
        }

    .banner-preview {
        margin-top: 14px;
        width: 100%;
        height: 220px;
        border-radius: 14px;
        border: 1px dashed #d8d8d5;
        background: #f8f8f7;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 8px;
        color: #a1a19d;
        overflow: hidden;
    }

        .banner-preview i {
            font-size: 28px;
        }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a1a;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
    }

        .btn-save:hover {
            opacity: 0.9;
            color: #fff;
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 0.5px solid #d6d6d2;
        background: #fff;
        color: #555;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
    }

        .btn-cancel:hover {
            background: #f5f5f4;
            color: #1a1a1a;
        }

    .img-preview span {
        font-size: 13px;
    }

    .toggle-aktif {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: #EAF3DE;
        color: #3B6D11;
        border: 0.5px solid #97C459;
        user-select: none;
    }

    .toggle-pasif {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: #FCEBEB;
        color: #A32D2D;
        border: 0.5px solid #F09595;
        user-select: none;
    }

    .toggle-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
        display: inline-block;
    }

</style>

<div class="page-header">
    <a asp-action="Index" asp-controller="CourseCategory" asp-area="Admin" class="btn-back">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="page-title">Yeni kurs kategori ekle</h4>
</div>

<form method="post" asp-action="CreateCourseCategory" asp-controller="CourseCategory" asp-area="Admin">
    <label>Kurs kategori adı </label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />
    <label>Acıklama </label>
    <textarea type="text" asp-for="Description" class="form-control" rows3></textarea>
    <br />
    <label>İkon</label>
    <input type="text" asp-for="Icon" class="form-control" />
    <br />
    <label>Durum</label>
    <div style="margin-top:6px;">
        <input type="checkbox" asp-for="IsActive" id="isActive" style="display:none;" />
        <label id="toggleLabel" class="toggle-aktif" onclick="toggleStatus()">
            <span class="toggle-dot"></span>
            <span id="toggleText">Aktif</span>
        </label>
    </div>
    <br />
    <div class="form-footer">

        <a asp-action="Index"
           asp-controller="CourseCategory"
           asp-area="Admin"
           class="btn-cancel">
            <i class="bi bi-arrow-left"></i>
            İptal
        </a>

        <button type="submit" class="btn-save">
            <i class="bi bi-floppy"></i>
            Kaydet
        </button>
    </div>
</form>

<script>
    document.getElementById('isActive').checked = true;

    function toggleStatus() {
        const cb = document.getElementById('isActive');
        const label = document.getElementById('toggleLabel');
        const text = document.getElementById('toggleText');
        cb.checked = !cb.checked;

        if (cb.checked) {
            label.style.background = '#EAF3DE';
            label.style.color = '#3B6D11';
            label.style.borderColor = '#97C459';
            text.textContent = 'Aktif';
        } else {
            label.style.background = '#FCEBEB';
            label.style.color = '#A32D2D';
            label.style.borderColor = '#F09595';
            text.textContent = 'Pasif';
        }
    }
</script>