@model UpdateCourseDto

@{
    ViewData["Title"] = "Kurs Güncelleme Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>

    .section-card {
        background: #ffffff;
        border: 0.5px solid #e0e0de;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

        .field label {
            font-size: 13px;
            font-weight: 500;
            color: #555;
        }

    .form-control {
        border: 0.5px solid #dcdcd8;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 15px;
        box-shadow: none !important;
    }

        .form-control:focus {
            border-color: #1a1a1a;
        }

    .banner-preview {
        margin-top: 14px;
        width: 100%;
        height: 220px;
        border-radius: 14px;
        border: 1px dashed #d8d8d5;
        background: #f8f8f7;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 8px;
        color: #a1a19d;
        overflow: hidden;
    }

        .banner-preview i {
            font-size: 28px;
        }

    .form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a1a;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
    }

        .btn-save:hover {
            opacity: 0.9;
            color: #fff;
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 0.5px solid #d6d6d2;
        background: #fff;
        color: #555;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
    }

        .btn-cancel:hover {
            background: #f5f5f4;
            color: #1a1a1a;
        }

    .img-preview span {
        font-size: 13px;
    }

    
    .toggle-aktif {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: #EAF3DE;
        color: #3B6D11;
        border: 0.5px solid #97C459;
        user-select: none;
    }

    .toggle-pasif {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: #FCEBEB;
        color: #A32D2D;
        border: 0.5px solid #F09595;
        user-select: none;
    }

    .toggle-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
        display: inline-block;
    }
</style>

<form method="post">
    <input type="hidden" asp-for="CourseId" />
    <div class="section-card">

        <div class="section-label">
            <i class="bi bi-type"></i>
            Kurs Bilgisi
        </div>

        <div class="field">
            <label asp-for="ImageUrl">Resim URL</label>

            <input type="text"
                   asp-for="ImageUrl"
                   class="form-control"
                   placeholder="https://example.com/blog.jpg"
                   oninput="updateCoursePreview(this.value)" />

            <div class="banner-preview" id="coursePreview">
                <i class="bi bi-image"></i>
                <span>kurs Önizleme</span>
            </div>

            <label asp-for="Name">Kurs ismi</label>
            <input type="text" asp-for="Name" class="form-control" placeholder="kursun adını giriniz..." />

            <label asp-for="Price">Fiyat</label>
            <input type="text" asp-for="Price" class="form-control" />

            <label asp-for="CourseCategoryId">Kurs Kategorisi</label>
            <select asp-for="CourseCategoryId"
                    class="form-control"
                    asp-items="@((IEnumerable<SelectListItem>)ViewBag.courseCategoryList)"
                    style="height: 45px; font-size: 15px; padding: 8px 12px;">
                <option value="">Kategori Seçin</option>
            </select>

            <label>Durum</label>
            <div style="margin-top:6px;">
                <input type="checkbox" asp-for="IsActive" id="isActive" style="display:none;" />
                <label id="toggleLabel" class="toggle-aktif" onclick="toggleStatus()">
                    <span class="toggle-dot"></span>
                    <span id="toggleText">Aktif</span>
                </label>
            </div>
            <br />
        </div>

        <div class="form-footer">

            <a asp-action="Index"
               asp-controller="Course"
               asp-area="Admin"
               class="btn-cancel">
                <i class="bi bi-arrow-left"></i>
                İptal
            </a>

            <button type="submit" class="btn-save">
                <i class="bi bi-floppy"></i>
                Kaydet
            </button>
        </div>
    </div>
</form>

<script>
    function updateCoursePreview(url) {
        const preview = document.getElementById("coursePreview");
        if (url && url.trim() !== "") {
            preview.innerHTML = `<img src="${url}"
                                          style="width:100%; height:220px; object-fit:cover; border-radius:14px;"
                                          onerror="this.parentElement.innerHTML='<i class=&quot;bi bi-image&quot;></i><span>Görsel yüklenemedi</span>'" />`;
            } else {
                preview.innerHTML = `<i class="bi bi-image"></i><span>Course Önizleme</span>`;
            }
        }
    document.getElementById('isActive').checked = true;
    function toggleStatus() 
    {
        const cb = document.getElementById('isActive');
        const label = document.getElementById('toggleLabel');
        const text = document.getElementById('toggleText');
        cb.checked = !cb.checked;
        if (cb.checked) {
            label.style.background = '#EAF3DE';
            label.style.color = '#3B6D11';
            label.style.borderColor = '#97C459';
            text.textContent = 'Aktif';
        }
        else 
        {
            label.style.background = '#FCEBEB';
            label.style.color = '#A32D2D';
            label.style.borderColor = '#F09595';
            text.textContent = 'Pasif';
        }
    }
</script>

